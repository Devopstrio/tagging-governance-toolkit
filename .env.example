# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Tagging Governance Toolkit Platform"

# Security
SECRET_KEY=tagginggovernancetoolkitsecretkey12345
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tagging_governance_db

# Redis / Task Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Governance Config
ENFORCEMENT_MODE=audit # audit, warn, block
MIN_COMPLIANCE_SCORE=80

# Monitoring
PROMETHEUS_METRICS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Grafana Dashboard
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=admin
